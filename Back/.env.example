# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/djtrip

# ─── JWT Secrets (REQUIRED — generate strong random strings) ──────────────────
# Example: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
REFRESH_TOKEN_SECRET=
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── OAuth Configuration (REQUIRED for Google/Facebook login) ──────────────────
# Get from Google Cloud Console: https://console.cloud.google.com
# - Create OAuth 2.0 Web Application credentials
# - Copy the Client ID here (format: xxxxx.apps.googleusercontent.com)
GOOGLE_CLIENT_ID=

# Get from Facebook Developers: https://developers.facebook.com
# - Create an app and get the App ID
FACEBOOK_APP_ID=

# ─── Cloudinary (for image uploads) ──────────────────────────────────────────
CLOUD_NAME=
API_KEY=
API_SECRET=

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=

# ─── CORS (production only — comma-separated allowed origins) ─────────────────
ALLOWED_ORIGINS=https://yourapp.com
