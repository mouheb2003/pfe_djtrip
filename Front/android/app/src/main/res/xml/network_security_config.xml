<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Debug overrides - allow all SSL certificates for development -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
    <!-- Allow SSL certificate bypass for Paymee sandbox in development -->
    <domain-config>
        <domain includeSubdomains="true">sandbox.paymee.tn</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
    <!-- Allow cleartext traffic for local development -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
